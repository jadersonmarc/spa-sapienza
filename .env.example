# ── Banco (Postgres no Coolify) ──────────────────────────────────────────────
# Connection string do Postgres. Exponha a porta no Coolify para rodar migrations
# de fora. Ex.: postgresql://user:senha@HOST:5432/dbname
DATABASE_URL=

# ── Auth.js (NextAuth) — login do admin ──────────────────────────────────────
# Segredo para assinar a sessão JWT. Gere com: openssl rand -base64 32
AUTH_SECRET=
# URL base da app (produção). Ex.: https://sapienzalabs.com.br
AUTH_URL=

# ── Claude API (geração + recursos de IA) ────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Webhooks (auth máquina-a-máquina) ────────────────────────────────────────
# Validado em /api/generate-draft (entrada) e enviado ao n8n no publish (saída).
WEBHOOK_SECRET=
# URL do webhook do n8n (saída na publicação).
N8N_PUBLISH_WEBHOOK_URL=

# ── Storage de imagens do editor ─────────────────────────────────────────────
# Opção A (rec.): volume do Coolify — caminho montado e servido pela app.
UPLOAD_DIR=/data/uploads
# Opção B: Cloudflare R2 (S3) — preencher se usar R2 em vez do volume.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=

# ── Publicação social (n8n usa; aqui p/ referência) ──────────────────────────
# Page token do Facebook (EAA) de longa duração — publica no Instagram.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
