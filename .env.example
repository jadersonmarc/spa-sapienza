# ── Banco (Postgres) ─────────────────────────────────────────────────────────
# Connection string do Postgres (Drizzle usa para migrations e queries).
# Local: host público da VPS. Produção (app na VPS): host interno do Docker. Ex.:
# postgres://postgres:[PWD]@[HOST]:5432/postgres
DATABASE_URL=

# ── Auth.js (login do /admin: Credentials, sessão JWT) ───────────────────────
# Segredo para assinar a sessão. Gerar com: openssl rand -base64 32
AUTH_SECRET=

# ── Storage de imagens (S3-compatível — Cloudflare R2) ───────────────────────
# Endpoint da API S3 do R2. Ex.: https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Base pública para servir as imagens (r2.dev ou domínio custom). Ex.: https://pub-xxxx.r2.dev
S3_PUBLIC_URL=

# ── Claude API (geração + recursos de IA) ────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Webhooks (auth máquina-a-máquina) ────────────────────────────────────────
# Valida /api/generate-draft e /api/publish-scheduled (acionados pelo GitHub Actions).
WEBHOOK_SECRET=
# Base pública do site (links dos posts sociais e payloads). Default: https://sapienzalabs.com.br
SITE_URL=

# ── Publicação social (postagem direta pelo admin, por botão) ────────────────
# Instagram via Facebook Graph (Page token EAA de longa duração) + IG Business id.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
# LinkedIn: token OAuth + URN do autor (urn:li:person:... ou urn:li:organization:...).
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
