# ── Banco (Supabase Postgres) ────────────────────────────────────────────────
# Connection string do Supabase. Para migrations/app use o pooler (porta 6543)
# ou a conexão direta (5432). Ex.: postgresql://postgres:[PWD]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=

# ── Supabase (Auth + Storage) ────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Públicas (client). Espelham as de cima.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Claude API (geração + recursos de IA) ────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Webhooks (auth máquina-a-máquina) ────────────────────────────────────────
# Validado em /api/generate-draft (entrada) e enviado ao n8n no publish (saída).
WEBHOOK_SECRET=

# ── Publicação social (n8n usa; aqui p/ referência) ──────────────────────────
# Page token do Facebook (EAA) de longa duração — publica no Instagram.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# URL do webhook do n8n (saída na publicação).
N8N_PUBLISH_WEBHOOK_URL=
